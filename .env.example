# Scrap Mechanic user Challenges folder (Proton AppData path on Linux)
# SM_CHALLENGES_DIR=/home/you/.local/share/Steam/steamapps/compatdata/387990/pfx/drive_c/users/steamuser/AppData/Roaming/Axolot Games/Scrap Mechanic/User/User_XXXXX/Challenges

# Reference maps for performance benchmarking
# SM_REFERENCE_PRIVATE_DIR=/path/to/Challenges
# SM_REFERENCE_WORKSHOP_DIR=/path/to/steamapps/workshop/content/387990

# Minecraft schematic / WorldEdit export (default build source)
# MC_SCHEMATIC_PATH=/path/to/build.schem

# Minecraft resource pack assets (highest-priority pack; see also resourcepacks/)
# Additional packs go in ./resourcepacks/ — alphabetical order = priority,
# vanilla_assets/ (from download_vanilla_assets.py) is the lowest fallback.
# SM_ASSETS_DIR=./MyResourcePack/assets

# Performance limits (derived from reference challenge maps)
# MAX_PARTS_PER_CHUNK=12000
# MAX_CHUNK_FILE_MB=4.0
# WARN_TOTAL_PARTS=15000
# FAIL_TOTAL_PARTS=200000

# Highlighted connector voxels between floating islands (default: bright magenta FF00FF)
# CONNECTOR_COLOR=FF00FF
